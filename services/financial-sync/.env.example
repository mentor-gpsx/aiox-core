# ClickUp Configuration
CLICKUP_API_KEY=your_clickup_api_key_here
CLICKUP_TEAM_ID=your_team_id_here
CLICKUP_CRM_OFICIAL_ID=your_crm_oficial_list_id
CLICKUP_CRM_VENDAS_ID=your_crm_vendas_list_id

# Webhooks Configuration (para sincronização em TEMPO REAL)
WEBHOOKS_ENABLED=false
CLICKUP_WEBHOOK_URL=https://seu-dominio-publico.com/api/webhooks
CLICKUP_WEBHOOK_SECRET=seu_webhook_secret_opcional

# Sincronização
# SYNC_INTERVAL_MS=300000   # 5 minutos (padrão)
# Mude para: 3600000 (1 hora), 86400000 (1 dia), etc
SYNC_INTERVAL_MS=300000

# Database Configuration (Opcional - para integração futura)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=financial_sync
DB_USER=postgres
DB_PASSWORD=password

# API Configuration
API_PORT=3001
API_HOST=localhost

# Logging
LOG_LEVEL=info
